---
layout: base.njk
title: Home
---

<!-- Hero -->
<section id="hero">
  <div class="inner">
    <div class="hero-content">
      <p class="eyebrow">{{ copy.hero.eyebrow }}</p>
      <h1 class="hero-headline">
        {{ copy.hero.headline }}<br>
        <em>{{ copy.hero.headlineAccent }}</em><br>
        {{ copy.hero.headlineEnd }}
      </h1>
      <p class="hero-sub">{{ copy.hero.subheadline }}</p>
      <a href="{{ copy.hero.ctaHref }}" class="btn-primary">{{ copy.hero.ctaLabel }}</a>
    </div>
  </div>
</section>

<!-- Features -->
<section id="features">
  <div class="inner">
    <div class="features-header">
      <p class="eyebrow">{{ copy.features.eyebrow }}</p>
      <h2 class="features-headline">{{ copy.features.headline }}</h2>
    </div>
    <div class="features-grid">
      {% for item in copy.features.items %}
        <div class="feature-card">
          <div class="feature-icon">{{ item.icon }}</div>
          <h3 class="feature-title">{{ item.title }}</h3>
          <p class="feature-body">{{ item.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Download -->
<section id="download">
  <div class="inner">
    <p class="eyebrow">{{ copy.download.eyebrow }}</p>
    <h2 class="download-headline">{{ copy.download.headline }}</h2>
    <p class="download-sub">{{ copy.download.subheadline }}</p>
    <div class="store-buttons">
      <a href="{{ copy.download.appleHref }}" class="btn-store">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" fill="currentColor"/>
        </svg>
        <span class="btn-store-label">
          <span class="btn-store-sub">Download on the</span>
          <span class="btn-store-name">{{ copy.download.appleLabel }}</span>
        </span>
      </a>
      <a href="{{ copy.download.googleHref }}" class="btn-store">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3.18 23.76c.3.16.64.24.99.21l.1-.06L13.64 14l-3.27-3.27-7.19 13zm16.49-10.95l-2.35-1.35-3.65 3.54 3.66 3.66 2.32-1.33c.67-.38 1.11-1.07 1.11-1.76 0-.7-.44-1.38-1.09-1.76zM3.07.39C2.8.64 2.63 1.03 2.63 1.53v20.94c0 .5.17.9.44 1.14l.06.06L14 12.64v-.27L3.13.33l-.06.06z" fill="currentColor"/>
        </svg>
        <span class="btn-store-label">
          <span class="btn-store-sub">Get it on</span>
          <span class="btn-store-name">{{ copy.download.googleLabel }}</span>
        </span>
      </a>
    </div>
  </div>
</section>
