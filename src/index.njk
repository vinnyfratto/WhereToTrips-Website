---
layout: base.njk
---

<!-- ── Header ────────────────────────────────────────────── -->
<header>
  <div class="wrap nav">
    <a class="brand" href="#top">
      <span class="mark">{{ site.monogram }}</span>
      <span class="name">{{ site.brandName }}</span>
    </a>
    <nav class="nav-links">
      {%- for link in site.nav %}
      <a href="{{ link.href }}">{{ link.label }}</a>
      {%- endfor %}
    </nav>
    <div class="nav-cta">
      <a class="btn btn-primary" href="#download">{{ site.navCtaLabel }}</a>
    </div>
  </div>
</header>

<!-- ── Hero ────────────────────────────────────────────── -->
<a id="top"></a>
<section class="hero">
  <div class="wrap hero-grid">
    <div class="reveal">
      <span class="eyebrow">{{ copy.hero.eyebrow }}</span>
      <h1>{{ copy.hero.title.pre }}<span class="italic">{{ copy.hero.title.accent }}</span>{{ copy.hero.title.post }}</h1>
      <p class="lede">{{ copy.hero.lede }}</p>
      <div class="cta">
        <a class="btn btn-primary" href="{{ copy.hero.primaryBtn.href }}">{{ copy.hero.primaryBtn.label }}</a>
        <a class="btn btn-ghost" href="{{ copy.hero.ghostBtn.href }}">{{ copy.hero.ghostBtn.label }}</a>
      </div>
    </div>
    <div class="hero-media reveal reveal-delay-1">
      <img class="hero-img" src="{{ copy.hero.image.src }}" alt="{{ copy.hero.image.alt }}" loading="eager" />
      <div class="hero-badge">
        <span class="pulse"></span>
        <div>
          <div class="bt">{{ copy.hero.badge.title }}</div>
          <div class="bs">{{ copy.hero.badge.subtitle }}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Vibes Engine ────────────────────────────────────────────── -->
<section class="block" id="vibes">
  <div class="wrap">
    <div class="feature-split">
      <div class="feature-img-wrap reveal">
        <img id="vibes-img" class="feature-img" src="{{ copy.vibes.image.src }}" alt="{{ copy.vibes.image.alt }}" loading="lazy" />
        <div class="feature-stat" style="top: 28px; right: -20px;">
          <div class="sv">{{ copy.vibes.stat1.value }}</div>
          <div class="sl">{{ copy.vibes.stat1.label }}</div>
        </div>
        <div class="feature-stat" style="bottom: 40px; right: -20px;">
          <div class="sv">{{ copy.vibes.stat2.value }}</div>
          <div class="sl">{{ copy.vibes.stat2.label }}</div>
        </div>
      </div>
      <div class="feature-text reveal reveal-delay-1">
        <span class="eyebrow">{{ copy.vibes.eyebrow }}</span>
        <h2>{{ copy.vibes.title.pre }}<span class="italic">{{ copy.vibes.title.accent }}</span>{{ copy.vibes.title.post }}</h2>
        <p class="lede">{{ copy.vibes.lede }}</p>
        <p class="body-copy" style="margin-top: 16px;">{{ copy.vibes.body }}</p>
        <div class="chip-cloud">
          {%- for chip in copy.vibes.chips %}
          <span class="chip{% if loop.index0 % 4 == 0 %} accent{% endif %}{% if loop.first %} active{% endif %}"
                data-img="{{ chip.img }}" data-alt="{{ chip.alt }}">{{ chip.label }}</span>
          {%- endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Wander Together ────────────────────────────────────────────── -->
<section class="block" id="together" style="background: var(--card); border-top: 1px solid var(--wg200); border-bottom: 1px solid var(--wg200);">
  <div class="wrap">
    <div class="feature-split flip">
      <div class="feature-img-wrap reveal reveal-delay-1">
        <img class="feature-img" src="{{ copy.together.image.src }}" alt="{{ copy.together.image.alt }}" loading="lazy" />
      </div>
      <div class="feature-text reveal">
        <span class="eyebrow">{{ copy.together.eyebrow }}</span>
        <h2>{{ copy.together.title.pre }}<span class="italic">{{ copy.together.title.accent }}</span>{{ copy.together.title.post }}</h2>
        <p class="lede">{{ copy.together.lede }}</p>
        <p class="body-copy" style="margin-top: 16px;">{{ copy.together.body }}</p>
        <ul class="feature-list">
          {%- for item in copy.together.features %}
          <li>
            <span class="fi">{{ item.icon }}</span>
            <span>{{ item.label }}</span>
          </li>
          {%- endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ── Conversational Search ────────────────────────────────────────────── -->
<section class="block chat-section" id="chat">
  <div class="wrap">
    <div class="chat-grid">
      <div class="chat-text reveal">
        <span class="eyebrow">{{ copy.chat.eyebrow }}</span>
        <h2>{{ copy.chat.title.pre }}<span class="italic">{{ copy.chat.title.accent }}</span>{{ copy.chat.title.post }}</h2>
        <p class="lede">{{ copy.chat.lede }}</p>
        <div class="chat-bubbles">
          {%- for ex in copy.chat.examples %}
          <div class="bubble">{{ ex }}</div>
          {%- endfor %}
        </div>
      </div>
      <div class="chat-img-wrap reveal reveal-delay-1">
        <img class="chat-img" src="{{ copy.chat.image.src }}" alt="{{ copy.chat.image.alt }}" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- ── Download CTA ────────────────────────────────────────────── -->
<section class="block" id="download" style="padding-top: 0;">
  <div class="wrap">
    <div class="download-band reveal">
      <span class="eyebrow">{{ copy.download.eyebrow }}</span>
      <h2>{{ copy.download.title.pre }}<span class="italic">{{ copy.download.title.accent }}</span>{{ copy.download.title.post }}</h2>
      <p>{{ copy.download.body }}</p>
      <div class="store-btns">
        <a href="{{ copy.download.appleHref }}" class="store-btn">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <span class="store-btn-label">
            <span class="store-btn-sub">Download on the</span>
            <span class="store-btn-name">App Store</span>
          </span>
        </a>
        <a href="{{ copy.download.googleHref }}" class="store-btn">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3.18 23.76c.3.16.64.24.99.21l.1-.06L13.64 14l-3.27-3.27-7.19 13zm16.49-10.95l-2.35-1.35-3.65 3.54 3.66 3.66 2.32-1.33c.67-.38 1.11-1.07 1.11-1.76 0-.7-.44-1.38-1.09-1.76zM3.07.39C2.8.64 2.63 1.03 2.63 1.53v20.94c0 .5.17.9.44 1.14l.06.06L14 12.64v-.27L3.13.33l-.06.06z"/>
          </svg>
          <span class="store-btn-label">
            <span class="store-btn-sub">Get it on</span>
            <span class="store-btn-name">Google Play</span>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ── Footer ────────────────────────────────────────────── -->
<footer>
  <div class="wrap">
    <div class="foot-grid">
      <a class="brand" href="#top">
        <span class="mark">{{ site.monogram }}</span>
        <span class="name">{{ site.brandName }}</span>
      </a>
      <div class="foot-links">
        {%- for col in site.footerCols %}
        <div class="foot-col">
          <h4>{{ col.heading }}</h4>
          {%- for link in col.links %}
          {%- if link.href %}
          <a href="{{ link.href }}">{{ link.label }}</a>
          {%- else %}
          <span>{{ link.label }}</span>
          {%- endif %}
          {%- endfor %}
        </div>
        {%- endfor %}
      </div>
    </div>
    <div class="foot-bottom">
      <span>© <span id="year"></span> {{ site.brandName }}. All rights reserved.</span>
      <span>Photography via <a href="https://www.pexels.com" target="_blank" rel="noopener">Pexels</a></span>
    </div>
  </div>
</footer>
