---
layout: layouts/base.njk
permalink: /dashboard/index.html
title: "Affiliate Dashboard — WhereTo"
description: "WhereTo affiliate dashboard."
eleventyExcludeFromCollections: true
---
<link rel="stylesheet" href="/assets/account.css?v={{ buildTime }}" />
<main id="wt-dash-page">

  {# Loading / gate #}
  <div id="wt-dash-gate" class="gate-msg">Loading your dashboard…</div>

  {# Not an affiliate #}
  <div id="wt-dash-notaff" class="acct" style="display:none;">
    <div class="acct-card" style="text-align:center;">
      <p class="eyebrow">Affiliate program</p>
      <h1>You're not an affiliate yet</h1>
      <p class="acct-sub">This dashboard is for WhereTo affiliates. Affiliate accounts are invitation-only.</p>
      <p><a class="btn btn-primary" href="/account/profile/">Back to my account</a></p>
      <p class="acct-links"><a href="/partners/creators/">Learn about the creator program</a></p>
    </div>
  </div>

  {# Dashboard #}
  <div id="wt-dash" class="dash" data-wt-page="dashboard" style="display:none;">

    <div class="dash-head">
      <div>
        <p class="eyebrow">Affiliate dashboard</p>
        <h1>Your performance</h1>
      </div>
      <div style="display:flex; gap:10px; align-items:center;">
        <a class="btn btn-ghost" href="#profile">Account settings</a>
        <button id="wt-logout" type="button" class="btn btn-ghost">Log out</button>
      </div>
    </div>

    {# Prominent code + share links #}
    <div class="code-banner">
      <p class="eyebrow">Your affiliate code</p>
      <p class="code" id="dash-code">--------</p>
      <p class="share-label">Share link</p>
      <a href="#" data-copy id="dash-link">…</a>
      <div id="dash-vanity-row" style="display:none;">
        <p class="share-label">Custom link</p>
        <a href="#" data-copy id="dash-vanity">…</a>
      </div>
      <p class="meta">Commission rate: <strong id="dash-rate">5%</strong> &nbsp;·&nbsp; Status: <strong id="dash-status">active</strong></p>
    </div>

    {# Stat cards #}
    <div class="stat-grid">
      <div class="stat-card"><p class="label">Link clicks</p><p class="value" id="card-clicks">0</p></div>
      <div class="stat-card"><p class="label">Referred signups</p><p class="value" id="card-referrals">0</p></div>
      <div class="stat-card"><p class="label">Bookings</p><p class="value" id="card-bookings">0</p></div>
      <div class="stat-card">
        <p class="label">Commission earned</p>
        <p class="value" id="card-commission">$0.00</p>
        <p class="sub">Pending <span id="comm-pending">$0</span> · Approved <span id="comm-approved">$0</span> · Paid <span id="comm-paid">$0</span></p>
      </div>
    </div>

    {# Charts #}
    <div class="chart-grid">
      <div class="chart-card">
        <h3>Referred signups (last 90 days)</h3>
        <div class="canvas-wrap"><canvas id="chart-signups"></canvas></div>
      </div>
      <div class="chart-card">
        <h3>Bookings &amp; commission (last 90 days)</h3>
        <div class="canvas-wrap"><canvas id="chart-bookings"></canvas></div>
      </div>
      <div class="chart-card full">
        <h3>Conversion funnel</h3>
        <div class="canvas-wrap"><canvas id="chart-funnel"></canvas></div>
      </div>
    </div>

    {# Embedded profile editor (shared with /account/profile) #}
    <div class="acct-card" id="profile" style="margin-top:10px;">
      <h2 class="acct-section-title" style="margin-top:0;">Account &amp; travel preferences</h2>
      <div id="wt-prof-alert" class="alert" role="status" aria-live="polite"></div>

      <form id="wt-profile-form" novalidate>
        <div class="field-row">
          <div class="field"><label for="wt-first">First name</label><input id="wt-first" type="text" autocomplete="given-name" /></div>
          <div class="field"><label for="wt-last">Last name</label><input id="wt-last" type="text" autocomplete="family-name" /></div>
        </div>
        <div class="field">
          <label for="wt-email">Email <span class="hint">(managed by your login)</span></label>
          <input id="wt-email" type="email" disabled />
        </div>
        <div class="field-row">
          <div class="field"><label for="wt-phone">Phone <span class="hint">(optional)</span></label><input id="wt-phone" type="tel" autocomplete="tel" /></div>
          <div class="field"><label for="wt-photo">Profile photo URL <span class="hint">(optional)</span></label><input id="wt-photo" type="url" placeholder="https://…" /></div>
        </div>
        <label class="check"><input id="wt-marketing" type="checkbox" /><span>Send me travel ideas and product updates by email.</span></label>

        <h2 class="acct-section-title">Flight preferences</h2>
        <div class="field"><label for="wt-airport">Nearest airport <span class="hint">(name or IATA code)</span></label><input id="wt-airport" type="text" placeholder="e.g. JFK" /></div>
        <div class="field-row">
          <div class="field">
            <label for="wt-seat">Seat class</label>
            <select id="wt-seat">
              <option value="">No preference</option>
              <option value="economy">Economy</option>
              <option value="economy_plus">Economy Plus</option>
              <option value="premium_economy">Premium Economy</option>
              <option value="business">Business</option>
              <option value="first">First</option>
            </select>
          </div>
          <div class="field">
            <label for="wt-stops">Stops</label>
            <select id="wt-stops">
              <option value="">No preference</option>
              <option value="nonstop">Nonstop only</option>
              <option value="1_layover">Up to 1 layover</option>
              <option value="2_layovers">Up to 2 layovers</option>
            </select>
          </div>
        </div>
        <div class="field"><label for="wt-airlines">Preferred airlines <span class="hint">(IATA codes, comma-separated)</span></label><input id="wt-airlines" type="text" placeholder="e.g. AA, DL, B6" /></div>
        <div class="field-row">
          <div class="field">
            <label for="wt-budgetflex">Budget flexibility</label>
            <select id="wt-budgetflex">
              <option value="">No preference</option>
              <option value="none">None — strict budget</option>
              <option value="2pct">Up to 2% over</option>
              <option value="5pct">Up to 5% over</option>
              <option value="10pct">Up to 10% over</option>
            </select>
          </div>
          <div class="field">
            <label for="wt-dateflex">Date flexibility</label>
            <select id="wt-dateflex">
              <option value="">No preference</option>
              <option value="none">Exact dates</option>
              <option value="1day">± 1 day</option>
              <option value="2days">± 2 days</option>
              <option value="3days">± 3 days</option>
              <option value="1week">± 1 week</option>
            </select>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Save changes</button>
      </form>
    </div>

  </div>
</main>
<script type="module" src="/assets/js/wt-dashboard.js?v={{ buildTime }}"></script>
