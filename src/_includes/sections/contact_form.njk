<section class="block{% if s.background %} tint{% endif %}" id="{{ s.id or 'contact' }}">
  <div class="wrap">
    <div class="sec-head center reveal">
      {% if s.eyebrow %}<span class="eyebrow">{{ s.eyebrow }}</span>{% endif %}
      {% if s.title %}<h2>{{ s.title.pre }}<span class="italic">{{ s.title.accent }}</span>{{ s.title.post }}</h2>{% endif %}
      {% if s.body %}<p class="lede">{{ s.body }}</p>{% endif %}
    </div>
    <form class="contact-form reveal reveal-delay-1" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="{{ site.forms.accessKey }}" />
      <input type="hidden" name="subject" value="{{ s.subject or 'WhereTo contact' }}" />
      <input type="hidden" name="intent" value="{{ s.intent or 'contact' }}" />
      <input type="text" name="name" placeholder="Your name" aria-label="Your name" required />
      <input type="email" name="email" placeholder="you@email.com" aria-label="Email address" required />
      {% if s.company %}<input type="text" name="company" placeholder="Company / organization" aria-label="Company or organization" />{% endif %}
      <textarea name="message" rows="5" placeholder="{{ s.placeholder or 'How can we help?' }}" aria-label="Message" required></textarea>
      <button type="submit" class="btn btn-primary">{{ s.buttonLabel or 'Send message' }}</button>
    </form>
  </div>
</section>
