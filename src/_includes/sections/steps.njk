<section class="block{% if s.background %} tint{% endif %}"{% if s.id %} id="{{ s.id }}"{% endif %}>
  <div class="wrap">
    {% if s.eyebrow or s.title or s.lede %}
    <div class="sec-head{% if s.center %} center{% endif %} reveal">
      {% if s.eyebrow %}<span class="eyebrow">{{ s.eyebrow }}</span>{% endif %}
      {% if s.title %}<h2>{{ s.title.pre }}<span class="italic">{{ s.title.accent }}</span>{{ s.title.post }}</h2>{% endif %}
      {% if s.lede %}<p class="lede">{{ s.lede }}</p>{% endif %}
    </div>
    {% endif %}
    <div class="steps-grid reveal reveal-delay-1">
      {% for step in s.steps %}
      <div class="step-card">
        <div class="step-num">{{ loop.index }}</div>
        <h3>{{ step.title }}</h3>
        <p>{{ step.body }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
