---
layout: layouts/base.njk
---
<section class="hero">
  <div class="wrap hero-grid">
    <div class="reveal">
      <span class="eyebrow">Destinations</span>
      <h1>{{ title }}</h1>
      {% if tagline %}<p class="lede">{{ tagline }}</p>{% endif %}
      <div class="cta">
        <a class="btn btn-primary" href="#download">Get the App to See My Matches</a>
        <a class="btn btn-ghost" href="/destinations/">All lists</a>
      </div>
    </div>
    <div class="hero-media reveal reveal-delay-1">
      <img class="hero-img" src="{{ heroImage }}" alt="{{ heroAlt or title }}" loading="eager" />
    </div>
  </div>
</section>

{% if picks %}
<section class="block tint">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">The shortlist</span>
      <h2>{{ listHeading or "Where to go" }}</h2>
      {% if intro %}<p class="lede">{{ intro }}</p>{% endif %}
    </div>
    <div class="tile-grid reveal reveal-delay-1" style="--cols: 2;">
      {% for p in picks %}
      <div class="tile">
        <h3>{{ p.name }}</h3>
        {% if p.blurb %}<p>{{ p.blurb }}</p>{% endif %}
        {% if p.priceNote %}<p style="color: var(--rust); font-weight: 600; margin-top: 8px;">{{ p.priceNote }}</p>{% endif %}
      </div>
      {% endfor %}
    </div>
    <p class="app-disclaimer reveal">These picks are illustrative. Live availability and pricing are matched to you in the WhereTo app.</p>
  </div>
</section>
{% endif %}

{% if relatedVibe %}
<section class="block">
  <div class="wrap" style="text-align: center;">
    <span class="eyebrow reveal">Browse by feeling</span>
    <p class="lede reveal" style="margin: 12px auto 24px;">Prefer to start from a mood instead of a number?</p>
    <a class="btn btn-ghost reveal" href="{{ relatedVibe.href }}">Explore the {{ relatedVibe.label }} vibe →</a>
  </div>
</section>
{% endif %}

{% set s = { id: "download", eyebrow: "Ready to wander?", title: { pre: "Your next trip is ", accent: "waiting", post: "." }, body: "Get personalized matches for your budget, dates, and departure city — in the WhereTo app." } %}
{% include "sections/cta_band.njk" %}
