<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<meta name="theme-color" content="#1F3A4D" />
<title>{{ title or site.metaTitle }}</title>
<meta name="description" content="{{ description or site.metaDescription }}" />
<link rel="canonical" href="{{ site.url }}{{ page.url }}" />
<meta property="og:site_name" content="{{ site.brandName }}" />
<meta property="og:title" content="{{ title or site.metaTitle }}" />
<meta property="og:description" content="{{ description or site.metaDescription }}" />
<meta property="og:type" content="website" />
<meta property="og:url" content="{{ site.url }}{{ page.url }}" />
<meta name="twitter:card" content="summary_large_image" />
