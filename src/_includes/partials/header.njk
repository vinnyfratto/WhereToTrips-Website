{%- set navCta = site.cta.post if site.launchMode == "post" else site.cta.pre -%}
<header>
  <div class="wrap nav">
    <a class="brand" href="/" aria-label="{{ site.brandName }} home">
      <img class="brand-logo" src="/assets/whereto-logo.svg" alt="{{ site.brandName }}" width="156" height="31" />
    </a>
    <nav class="nav-links" aria-label="Primary">
      {%- for link in site.nav %}
      <a href="{{ link.href }}">{{ link.label }}</a>
      {%- endfor %}
      <div class="nav-dropdown">
        <button type="button" aria-haspopup="true">Partner With Us <span class="caret">▾</span></button>
        <div class="nav-dropdown-menu">
          {%- for link in site.partnerNav %}
          <a href="{{ link.href }}">{{ link.label }}</a>
          {%- endfor %}
        </div>
      </div>
    </nav>
    <div class="nav-cta">
      <a class="btn btn-primary" href="/account/login/" data-wt-account>Log In</a>
    </div>
    <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mobile-menu" id="mobile-menu">
    {%- for link in site.nav %}
    <a href="{{ link.href }}">{{ link.label }}</a>
    {%- endfor %}
    <span class="mobile-menu-label">Partner With Us</span>
    {%- for link in site.partnerNav %}
    <a class="mobile-sub" href="{{ link.href }}">{{ link.label }}</a>
    {%- endfor %}
    <a class="btn btn-primary mobile-cta" href="/account/login/" data-wt-account>Log In</a>
  </div>
</header>
